# Langfuse Tracing (Optional)
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# Frontend API Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000/api/modernize

# Core Workflow Configuration
WORKFLOW_MODEL_PROVIDER=openai
API_KEY=nvapi-...

# OpenAI/Provider Settings
OPENAI_MODELS=qwen/qwen3.5-122b-a10b
OPENAI_ENDPOINT_BASE=https://integrate.api.nvidia.com/v1
OPENAI_ENABLE_CACHE=1
OPENAI_MAX_TOKENS=16384
OPENAI_MAX_CALLS_PER_MINUTE=35
OPENAI_INTER_REQUEST_DELAY_SECONDS=1.5
OPENAI_429_BASE_DELAY_SECONDS=60
OPENAI_429_MAX_DELAY_SECONDS=900
LLM_RETRY_DELAYS=3,6,12,24
WORKFLOW_BATCH_SIZE=1

# Modernization Parameters
LLM_TEMPERATURE=0.1
USE_CACHE=1
CACHE_TTL_SECONDS=604800
ENABLE_REFLECTION=1
REFLECTION_MAX_ITERS=2
ENABLE_RAG=1
WORKFLOW_MIN_SCORE_DELTA=8
MODERN_RETRY_THRESHOLD_PERCENT=60
MODERNIZER_CHUNK_MAX_CHARS=1400

# Multi-Agent Model Routing (Analyzer)
ANALYZER_MODEL=deepseek-ai/deepseek-v3.2
ANALYZER_API_KEY=nvapi-...
ANALYZER_ENDPOINT_BASE=https://integrate.api.nvidia.com/v1
ANALYZER_THINKING=1
ANALYZER_ENABLE_THINKING=1
ANALYZER_THINKING_KEY=thinking
ANALYZER_REASONING_EFFORT=high
ANALYZER_TEMPERATURE=1.0
ANALYZER_TOP_P=0.95
ANALYZER_MAX_TOKENS=8192

# Multi-Agent Model Routing (Modernizer)
MODERNIZER_MODEL=meta/llama-3.3-70b-instruct
MODERNIZER_API_KEY=nvapi-...
MODERNIZER_ENDPOINT_BASE=https://integrate.api.nvidia.com/v1
MODERNIZER_TEMPERATURE=0.1
MODERNIZER_TOP_P=0.85
MODERNIZER_ENABLE_THINKING=0
MODERNIZER_MAX_TOKENS=12288

# Multi-Agent Model Routing (Fixer)
FIXER_MODEL=meta/llama-3.3-70b-instruct
FIXER_API_KEY=nvapi-...
FIXER_ENDPOINT_BASE=https://integrate.api.nvidia.com/v1
FIXER_TEMPERATURE=0.1
FIXER_TOP_P=0.7
FIXER_MAX_TOKENS=4096
